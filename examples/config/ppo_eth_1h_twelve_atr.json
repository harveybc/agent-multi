{
    "mode": "train",
    "env_plugin": "gym_fx_env",
    "agent_plugin": "ppo_agent",
    "pipeline_plugin": "rl_pipeline",
    "optimizer_plugin": "default_optimizer",

    "env_mode": "training",
    "input_data_file": "./data/project2/ethusdt_1h/d4.csv",
    "date_column": "DATE_TIME",
    "price_column": "CLOSE",
    "headers": true,
    "window_size": 32,
    "initial_cash": 10000.0,
    "position_size": 1.0,
    "commission": 0.001,
    "slippage": 0.0,

    "data_feed_plugin": "default_data_feed",
    "broker_plugin": "default_broker",
    "strategy_plugin": "default_strategy",
    "preprocessor_plugin": "default_preprocessor",
    "reward_plugin": "pnl_reward",
    "metrics_plugin": "default_metrics",

    "total_timesteps": 50000,
    "learning_rate": 0.0003,
    "n_steps": 1024,
    "batch_size": 128,
    "n_epochs": 10,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "clip_range": 0.2,
    "ent_coef": 0.01,
    "vf_coef": 0.5,

    "save_model": "./examples/results/p2_pilot/ppo_eth_1h.zip",
    "results_file": "./examples/results/p2_pilot/ppo_eth_1h_summary.json",
    "save_config": "./examples/results/p2_pilot/ppo_eth_1h_config_out.json",
    "eval_seed": 0,
    "train_seed": 0,
    "device": "cpu",
    "agent_verbose": 0,
    "quiet_mode": true,

    "_notes": "P2.5 pilot — ETH 1h, Block B train slice d4 (pre-2020), smoke 50k steps."
}
