{
    "mode": "train",
    "env_plugin": "gym_fx_env",
    "agent_plugin": "sac_agent",
    "pipeline_plugin": "rl_pipeline",
    "optimizer_plugin": "default_optimizer",

    "env_mode": "training",
    "input_data_file": "./data/project2/btcusdt_1h/d4.csv",
    "date_column": "DATE_TIME",
    "price_column": "CLOSE",
    "headers": true,
    "window_size": 32,
    "initial_cash": 10000.0,
    "position_size": 0.01,
    "rel_volume": 0.05,
    "leverage": 1.0,
    "size_mode": "notional",
    "min_order_volume": 0.0,
    "max_order_volume": 100.0,
    "commission": 0.0002,
    "slippage": 0.0,

    "action_space_mode": "continuous",
    "continuous_action_threshold": 0.10,

    "data_feed_plugin": "default_data_feed",
    "broker_plugin": "default_broker",
    "strategy_plugin": "direct_atr_sltp",
    "atr_period": 14,
    "k_sl": 2.5,
    "k_tp": 4.0,
    "preprocessor_plugin": "default_preprocessor",
    "reward_plugin": "pnl_reward",
    "metrics_plugin": "default_metrics",

    "features_preset": "twelve",
    "asset": "btcusdt_1h",

    "total_timesteps": 500000,
    "learning_rate": 0.0001,
    "buffer_size": 200000,
    "learning_starts": 20000,
    "batch_size": 256,
    "tau": 0.005,
    "gamma": 0.99,
    "train_freq": 1,
    "gradient_steps": 1,
    "ent_coef": "auto",
    "use_sde": true,

    "save_model": "./examples/results/p4/sac_btc_1h_iter8.zip",
    "results_file": "./examples/results/p4/sac_btc_1h_iter8_summary.json",
    "save_config": "./examples/results/p4/sac_btc_1h_iter8_config_out.json",
    "eval_seed": 0,
    "eval_deterministic": false,
    "train_seed": 0,
    "device": "cuda",
    "agent_verbose": 0,
    "quiet_mode": true,

    "_notes": "P4 iter8 J8 — SAC BTC: widen SL/TP from (2.0,3.0) -> (2.5,4.0) matching PPO iter8ext winning geometry. Tests whether SAC also benefits from wider TP. Other params unchanged from sac_btc_1h_twelve_atr.json (lr 1e-4, learning_starts 20k, use_sde=true)."
}
