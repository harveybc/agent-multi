{
    "mode": "train",
    "env_plugin": "gym_fx_env",
    "agent_plugin": "sac_agent",
    "pipeline_plugin": "rl_pipeline",
    "optimizer_plugin": "default_optimizer",

    "env_mode": "training",
    "input_data_file": "./data/project2/eurusd_1h/d4.csv",
    "date_column": "DATE_TIME",
    "price_column": "CLOSE",
    "headers": true,
    "window_size": 32,
    "initial_cash": 10000.0,
    "position_size": 1000.0,
    "rel_volume": 0.01,
    "leverage": 10.0,
    "size_mode": "fx_units",
    "min_order_volume": 1000.0,
    "max_order_volume": 100000.0,
    "commission": 0.0005,
    "slippage": 0.0,

    "action_space_mode": "continuous",
    "continuous_action_threshold": 0.10,

    "data_feed_plugin": "default_data_feed",
    "broker_plugin": "default_broker",
    "strategy_plugin": "direct_atr_sltp",
    "atr_period": 14,
    "k_sl": 2.5,
    "k_tp": 4.0,
    "min_sltp_frac": 0.0005,
    "max_sltp_frac": 0.05,
    "preprocessor_plugin": "default_preprocessor",
    "reward_plugin": "pnl_reward",
    "metrics_plugin": "default_metrics",

    "features_preset": "twelve_macro",
    "asset": "eurusd_1h",

    "total_timesteps": 500000,
    "learning_rate": 0.0001,
    "buffer_size": 200000,
    "learning_starts": 20000,
    "batch_size": 256,
    "tau": 0.005,
    "gamma": 0.99,
    "train_freq": 1,
    "gradient_steps": 1,
    "ent_coef": "auto",
    "use_sde": true,

    "save_model": "./examples/results/p4/sac_eurusd_1h.zip",
    "results_file": "./examples/results/p4/sac_eurusd_1h_summary.json",
    "save_config": "./examples/results/p4/sac_eurusd_1h_config_out.json",
    "eval_seed": 0,
    "eval_deterministic": false,
    "train_seed": 0,
    "device": "cpu",
    "agent_verbose": 0,
    "quiet_mode": true,

    "_notes": "P4 J7 — SAC EURUSD 1h: mirror of sac_eth_1h_twelve_atr.json with EURUSD fx_units sizing + twelve_macro features + k_sl=2.5/k_tp=4.0 from PPO iter8ext winner + device=cpu (EURUSD macro features favor CPU per J4/J6 profile). 500k ts, use_sde=true."
}
